<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.bnr.mindcare.controllers.TherapistController"
            style="-fx-background-color: #f0f4f8;">

    <top>
        <HBox style="-fx-background-color: #1D9E75; -fx-padding: 15;">
            <Label text="MindCare — Therapist Dashboard"
                   style="-fx-text-fill: white; -fx-font-size: 18; -fx-font-weight: bold;"/>
        </HBox>
    </top>

    <left>
        <VBox spacing="5" style="-fx-padding: 10; -fx-background-color: #085041;">
            <Button text="My Patients" onAction="#showPatients" maxWidth="Infinity"
                    style="-fx-background-color: transparent; -fx-text-fill: white;"/>
            <Button text="Set Appointment" onAction="#showAppointment" maxWidth="Infinity"
                    style="-fx-background-color: transparent; -fx-text-fill: white;"/>
            <Button text="Logout" onAction="#handleLogout" maxWidth="Infinity"
                    style="-fx-background-color: transparent; -fx-text-fill: #ff6b6b;"/>
        </VBox>
    </left>

    <center>
        <StackPane style="-fx-padding: 20;">

            <VBox fx:id="patientsPane" spacing="10"
                  style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10;">
                <Label text="My Patients"
                       style="-fx-font-size: 18; -fx-font-weight: bold;"/>
                <TableView fx:id="patientsTable" prefHeight="300">
                    <columns>
                        <TableColumn fx:id="patientNameCol" text="Name" prefWidth="180"/>
                        <TableColumn fx:id="patientDiagnosisCol" text="Diagnosis" prefWidth="180"/>
                        <TableColumn fx:id="patientAppointmentCol" text="Appointment Date" prefWidth="180"/>
                    </columns>
                </TableView>
            </VBox>

            <VBox fx:id="appointmentPane" spacing="10" visible="false"
                  style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10;">
                <Label text="Set Appointment Date"
                       style="-fx-font-size: 18; -fx-font-weight: bold;"/>
                <Label text="Select Patient"/>
                <ComboBox fx:id="patientComboBox" maxWidth="Infinity"/>
                <Label text="Appointment Date (e.g. 2026-05-10)"/>
                <TextField fx:id="appointmentDate" promptText="YYYY-MM-DD"/>
                <Button text="Set Appointment" onAction="#handleSetAppointment"
                        style="-fx-background-color: #1D9E75; -fx-text-fill: white;"/>
                <Label fx:id="appointmentMessage"/>
            </VBox>

        </StackPane>
    </center>

</BorderPane>